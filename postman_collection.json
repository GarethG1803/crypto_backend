{
  "info": {
    "name": "Gamified Crypto Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5001/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Modules",
      "item": [
        {
          "name": "Get All Modules",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/modules"
          }
        },
        {
          "name": "Get Module by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/modules/what-is-cryptocurrency"
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Get Progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress"
          }
        },
        {
          "name": "Complete Lesson",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/progress/completeLesson",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": \"what-is-cryptocurrency\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Quiz",
      "item": [
        {
          "name": "Get Quiz Questions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quiz/what-is-cryptocurrency"
          }
        },
        {
          "name": "Submit Quiz",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/quiz/submit",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": \"what-is-cryptocurrency\",\n  \"answers\": [1, 1, 2]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Achievements",
      "item": [
        {
          "name": "Get Achievements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/achievements"
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/leaderboard"
          }
        }
      ]
    },
    {
      "name": "Simulator",
      "item": [
        {
          "name": "Get Portfolio",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/simulator/portfolio"
          }
        },
        {
          "name": "Buy Crypto",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/simulator/trade",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"crypto\": \"BTC\",\n  \"type\": \"buy\",\n  \"amount\": 0.1\n}"
            }
          }
        },
        {
          "name": "Sell Crypto",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/simulator/trade",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"crypto\": \"BTC\",\n  \"type\": \"sell\",\n  \"amount\": 0.05\n}"
            }
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/simulator/history"
          }
        }
      ]
    }
  ]
}
